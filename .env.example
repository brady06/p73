# Copy to ".env" for local development. Never commit real secrets.

# --- Local Express API only (npm run dev:api or dev:all)
# Production on Netlify uses Netlify Functions instead — set OPENAI_* in the Netlify UI.
OPENAI_API_KEY=

# Optional: defaults to gpt-4o-mini
OPENAI_MODEL=gpt-5.4-mini

# Optional: API listen port (default 8787). Must match Vite proxy target in vite.config.ts.
# PORT=8787

# --- Netlify (Site configuration → Environment variables — not this file on deploy)
# OPENAI_API_KEY   required for bias-score function
# OPENAI_MODEL     optional; defaults to gpt-4o-mini in netlify/functions/bias-score.ts

# --- Frontend: optional override if API is on another origin (no trailing slash)
# VITE_API_BASE_URL=https://your-site.netlify.app
